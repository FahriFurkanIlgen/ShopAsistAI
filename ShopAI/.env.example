# Server Configuration
PORT=3000
NODE_ENV=development

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Cache Configuration
CACHE_TTL_SECONDS=3600
FEED_UPDATE_CRON=0 * * * *

# E-commerce Site Configuration
# Add feed URLs for each site (comma-separated for multiple feeds)
SKECHERS_FEED_URL=https://www.skechers.com.tr/feed/google-shopping
SITE_NAME=Skechers Turkey

# CORS Configuration
# Allow multiple origins separated by commas, or use * for all origins (not recommended for production)
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5500,https://www.skechers.com.tr

# Logging
LOG_LEVEL=info
