{
  "name": "shopasistai",
  "version": "1.0.0",
  "description": "AI-powered shopping assistant for e-commerce sites with product recommendations via Google Feeds",
  "main": "dist/backend/backend/src/server.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "nodemon --watch backend/src --ext ts --exec ts-node backend/src/server.ts",
    "dev:frontend": "live-server frontend/src --port=3001",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc -p backend/tsconfig.json",
    "build:frontend": "echo 'Frontend build completed'",
    "start": "node dist/backend/backend/src/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,js,json,html,css}\""
  },
  "keywords": [
    "ai",
    "shopping",
    "assistant",
    "e-commerce",
    "chatbot",
    "product-recommendations"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.3",
    "openai": "^4.24.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "live-server": "^1.2.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
